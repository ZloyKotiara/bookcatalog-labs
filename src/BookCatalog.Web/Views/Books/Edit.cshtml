@model BookCatalog.Web.Models.Book
@{
    ViewData["Title"] = "Изменить книгу";
}

<h1>Изменить книгу</h1>

<form asp-action="Edit" class="form-card">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <label asp-for="Title"></label>
    <input asp-for="Title" class="input" />
    <span asp-validation-for="Title" class="text-danger"></span>

    <label asp-for="Author"></label>
    <input asp-for="Author" class="input" />
    <span asp-validation-for="Author" class="text-danger"></span>

    <label asp-for="Genre"></label>
    <input asp-for="Genre" class="input" />
    <span asp-validation-for="Genre" class="text-danger"></span>

    <label asp-for="Year"></label>
    <input asp-for="Year" class="input" />
    <span asp-validation-for="Year" class="text-danger"></span>

    <div class="actions">
        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a class="btn" asp-action="Index">Назад</a>
    </div>
</form>
