@model BookCatalog.Web.Models.Book
@{
    ViewData["Title"] = "Просмотр книги";
}

<h1>Просмотр книги</h1>

<div class="details-card">
    <p><strong>Название:</strong> @Model.Title</p>
    <p><strong>Автор:</strong> @Model.Author</p>
    <p><strong>Жанр:</strong> @Model.Genre</p>
    <p><strong>Год:</strong> @Model.Year</p>
</div>

<div class="actions">
    <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Изменить</a>
    <a class="btn" asp-action="Index">Назад</a>
</div>
