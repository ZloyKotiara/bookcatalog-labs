@model IEnumerable<BookCatalog.Web.Models.Book>
@{
    ViewData["Title"] = "Список книг";
}

<div class="page-header">
    <div>
        <h1>Список книг</h1>
        <p>Минимальное CRUD-приложение на ASP.NET Core MVC + PostgreSQL</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Добавить книгу</a>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Название</th>
            <th>Автор</th>
            <th>Жанр</th>
            <th>Год</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Title</td>
            <td>@item.Author</td>
            <td>@item.Genre</td>
            <td>@item.Year</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id">Просмотр</a> |
                <a asp-action="Edit" asp-route-id="@item.Id">Изменить</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Удалить</a>
            </td>
        </tr>
    }
    </tbody>
</table>
